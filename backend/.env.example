# Required for chat replies. Also required only if NEXT_PUBLIC_VOICE_TRANSCRIPTION_MODE=backend.
GEMINI_API_KEY=replace_me

# Comma-separated frontend origins. Use * only for local/testing.
CORS_ORIGINS=http://localhost:3000

# quota_saver | quality
APP_MODE=quota_saver

# Lightweight profile retrieval knobs
PROFILE_EMBED_MODEL=gemini-embedding-001
PROFILE_EMBED_DIM=256
PROFILE_TOP_K=3
PROFILE_MIN_SCORE=0.15
PROFILE_MAX_CONTEXT_CHARS=2800

# Upload guardrail for /api/transcribe
MAX_AUDIO_BYTES=12582912

# Optional comma-separated overrides.
# Quota saver prioritizes free-tier Lite models and minimal thinking.
GEMINI_QUOTA_SAVER_MODEL_CANDIDATES=gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-2.0-flash-lite

# Quality uses free-tier-safe models first. Pro preview is not in the default path because it has no Gemini API free tier.
GEMINI_QUALITY_MODEL_CANDIDATES=gemini-3-flash-preview,gemini-3.1-flash-lite,gemini-2.5-flash

# Legacy global override. Leave unset unless you want both modes to share one model list.
# GEMINI_CHAT_MODEL_CANDIDATES=gemini-3.5-flash,gemini-3.1-flash-lite

# Used only by /api/transcribe backend audio transcription.
GEMINI_TRANSCRIBE_MODEL_CANDIDATES=gemini-3.1-flash-lite,gemini-2.5-flash,gemini-2.5-flash-lite
