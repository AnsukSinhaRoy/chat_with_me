# Required for chat and backend transcription
OPENAI_API_KEY=replace_me

# Optional model overrides
# For a cheap/fast interview bot, gpt-4.1-mini is a safe default.
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# Comma-separated fallback override, optional:
# OPENAI_MODEL_CANDIDATES=gpt-4.1-mini,gpt-4.1-nano

# Comma-separated frontend origins. Use * only for local/testing.
CORS_ORIGINS=http://localhost:3000

# quota_saver | normal | quality
APP_MODE=quota_saver

# Lightweight profile retrieval knobs; lexical retrieval is used at runtime.
PROFILE_TOP_K=4
PROFILE_MIN_SCORE=0.10
PROFILE_MAX_CONTEXT_CHARS=2800

# Upload guardrail for /api/transcribe
MAX_AUDIO_BYTES=12582912
