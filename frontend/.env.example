# Required in Vercel for the frontend build.
# This must be the backend deployment URL, not the frontend URL.
# Example:
NEXT_PUBLIC_API_BASE_URL=https://your-backend.vercel.app

# quota_saver | quality
NEXT_PUBLIC_APP_MODE=quota_saver

# browser | backend
# browser = use the browser's SpeechRecognition API and send only text to /api/chat.
# backend = record audio and upload it to /api/transcribe for Gemini transcription.
NEXT_PUBLIC_VOICE_TRANSCRIPTION_MODE=browser

# Browser speech recognition language. en-IN works better for Indian English than en-US in many cases.
NEXT_PUBLIC_BROWSER_STT_LANG=en-IN

# Experimental. true asks supporting browsers to use on-device speech recognition only.
# Most browsers still do not reliably support this; keep false unless you know your target browser has local language packs.
NEXT_PUBLIC_BROWSER_STT_PROCESS_LOCALLY=false


# true = after Done, paste transcript briefly, then send automatically.
# false = only paste transcript into the input box for manual review.
NEXT_PUBLIC_AUTO_SEND_VOICE=true
