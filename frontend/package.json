{
  "name": "talk-to-ansuk-frontend",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NEXT_TELEMETRY_DISABLED=1 NEXT_PRIVATE_BUILD_WORKER=0 node ./node_modules/next/dist/bin/next build --turbopack",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit"
